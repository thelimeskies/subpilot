# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-local-development-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web

# --- CORS / Frontend origins (Vite dev servers) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# --- Database ---
# When running via docker-compose, host is "db". Set to "localhost" for non-Docker usage.
DATABASE_URL=postgres://subpilot:replace-with-local-password@db:5432/subpilot
# Or, if you prefer discrete vars:
POSTGRES_DB=subpilot
POSTGRES_USER=subpilot
POSTGRES_PASSWORD=replace-with-local-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (Celery broker + cache + idempotency) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Email (MailHog in compose) ---
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=0
DEFAULT_FROM_EMAIL=SubPilot <no-reply@subpilot.test>

# --- Crypto (Fernet key for encrypting MFA secrets, webhook secrets, payment tokens) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=changeme-generate-with-fernet-generate_key-base64-32-bytes==

# --- Nomba platform-managed mode ---
NOMBA_SANDBOX_BASE_URL=https://sandbox.nomba.com
NOMBA_LIVE_BASE_URL=https://api.nomba.com
NOMBA_PLATFORM_TEST_ACCOUNT_ID=
NOMBA_PLATFORM_TEST_SUB_ACCOUNT_ID=
NOMBA_PLATFORM_TEST_CLIENT_ID=
NOMBA_PLATFORM_TEST_CLIENT_SECRET=
NOMBA_PLATFORM_LIVE_ACCOUNT_ID=
NOMBA_PLATFORM_LIVE_SUB_ACCOUNT_ID=
NOMBA_PLATFORM_LIVE_CLIENT_ID=
NOMBA_PLATFORM_LIVE_CLIENT_SECRET=
NOMBA_HTTP_USER_AGENT=SubPilot/0.1 (+https://subpilot.kylodo.com; nomba-api-client)
# Used by the central webhook: /api/v1/payments/webhooks/nomba/
NOMBA_WEBHOOK_SECRET=
NOMBA_CHECKOUT_CALLBACK_URL=http://localhost:5174/payments/nomba/callback

# --- Platform admin bootstrap ---
PLATFORM_ADMIN_EMAIL=admin@example.test
PLATFORM_ADMIN_PASSWORD=replace-with-local-admin-password

# --- Demo flags ---
DEMO_MFA_BYPASS_CODE=replace-with-local-demo-code
